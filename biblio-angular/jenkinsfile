pipeline {
    agent any

    stages {
        stage('Github checkout') {
            steps {
                script {
                    git credentialsId: 'github-login',
                        url: 'git@https://github.com/6p-rien/projet-biblio.git',
                        branch: 'adam'
                }
            }
        }

        stage('Maven build') {
            // Demander à Jenkins d'exécuter le builder dans un container Docker
            agent {
                docker {
                    image 'maven:3.9.11-eclipse-temurin-21'
                    args '''
                        -v $HOME/.m2:/root/.m2:z
                        -u root
                        --network devops
                    ''' // On se place sur le réseau devops pour pouvoir contacter sonar !
                    reuseNode true // Permet de garder le même workspace entre les différents agents (any & docker)
                }
            }

            steps {
                dir('biblio-back') {
                    withSonarQubeEnv('sonar-id') {
                        sh "mvn verify sonar:sonar -Dsonar.projectKey=quest-boot -Dsonar.projectName='biblio-back'"
                    }
                }
            }
        }

        stage('Docker build') {
            steps {
                dir('quest-boot') {
                    sh 'docker build -t biblioBack .'
                }
            }
        }
    }
}
