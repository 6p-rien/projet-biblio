pipeline {
    agent any

    stages {
        stage('Github checkout') {
            steps {
                script {
                    git credentialsId: 'github-login',
                        url: 'git@github.com:6p-rien/projet-biblio.git',
                        branch: 'adam'
                }
            }
        }

        stage('Build') {
            // Demander à Jenkins d'exécuter le builder dans un container Docker
            agent {
                docker {
                    image 'node:lts-bullseye'
                    args '''
                        -v $HOME/.npm:/root/.npm:z
                        -u root
                    '''
                    reuseNode true // Permet de garder le même workspace entre les différents agents (any & docker)
                }
            }

            stages {
                stage('Install dependencies') {
                    steps {
                        dir('biblio-angular') {
                            sh 'npm install'
                        }
                    }
                }

                stage('Sonar analysis') {
                    steps {
                        dir('biblio-angular') {
                            sh './node_modules/.bin/sonar-scanner -Dsonar.projectKey=biblio-angular'
                        }
                    }
                }

                stage('NPM Build') {
                    steps {
                        dir('biblio-angular') {
                            sh './node_modules/.bin/ng build'
                        }
                    }
                }
            }
        }

        stage('Docker build') {
            steps {
                dir('biblio-angular') {
                    sh 'docker build -t biblioAngular -f \"$WORKSPACE/biblio-angular/Dockerfile\" \"$WORKSPACE\"'
                }
            }
        }

        stage('Docker deploy') {
            steps {
                // Se placer dans le répertoire (éventuellement) dans lequel se trouve le docker-compose.yml
                // dir('ANGULAR/quest-angular') {
                sh 'docker compose up -d --no-deps angular'
                // }
            }
        }
    }
}
